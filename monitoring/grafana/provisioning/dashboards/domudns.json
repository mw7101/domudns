{
  "title": "DNS Stack",
  "uid": "domudns",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(dns_queries_total, node)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "label": "Node"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Query-Rate gesamt (pro Sekunde)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (result) (rate(dns_queries_total{node=~\"$node\"}[1m]))",
          "legendFormat": "{{ result }}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Upstream-Latenz p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(dns_query_duration_seconds_bucket{result=\"forwarded\",node=~\"$node\"}[1m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(dns_query_duration_seconds_bucket{result=\"forwarded\",node=~\"$node\"}[1m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(dns_query_duration_seconds_bucket{result=\"forwarded\",node=~\"$node\"}[1m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Geblockte Domains (pro Sekunde)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 100 }
          ]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(dns_queries_total{result=\"blocked\",node=~\"$node\"}[1m]))",
          "legendFormat": "blocked/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "green", "value": 0.6 }
          ]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(dns_queries_total{result=\"cached\",node=~\"$node\"}[5m])) / sum(rate(dns_queries_total{node=~\"$node\"}[5m]))",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "id": 5,
      "title": "Node Status",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=\"domudns\"}",
          "legendFormat": "{{ node }}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Query-Rate pro Node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (node) (rate(dns_queries_total[1m]))",
          "legendFormat": "{{ node }}"
        }
      ]
    }
  ]
}
